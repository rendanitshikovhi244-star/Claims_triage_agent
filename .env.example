# Copy this file to claims_agent/.env and fill in your credentials.
# NEVER commit claims_agent/.env — it is excluded by .gitignore.

# --- HuggingFace (free, good for testing) ---
HUGGINGFACE_API_KEY=hf_your_key_here
HF_MODEL=huggingface/Qwen/Qwen2.5-72B-Instruct

# --- Google Gemini (option: set in config.py as DEFAULT_MODEL = "gemini-2.5-flash") ---
# GOOGLE_API_KEY=your_key_from_aistudio.google.com
# GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
SESSION_DB_URL=sqlite+aiosqlite:///./claims_sessions.db
